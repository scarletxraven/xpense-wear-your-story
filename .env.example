# XPENSE — Environment variables template
# Copy to .env and fill in real values when wiring a backend.

# Public app config (exposed to the browser via Vite)
VITE_API_BASE_URL=
VITE_SITE_URL=

# Auth (e.g. Supabase publishable / anon key)
VITE_AUTH_URL=
VITE_AUTH_PUBLISHABLE_KEY=

# Payments (publishable keys only)
VITE_STRIPE_PUBLISHABLE_KEY=

# Server-only secrets (NEVER prefix with VITE_)
API_BASE_URL=
AUTH_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
